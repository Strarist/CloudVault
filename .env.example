# CloudVault backend environment (copy to `.env` and fill values)
# Never commit your real `.env` — it is gitignored. See SECURITY.md.

PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/cloudvault
JWT_SECRET=change-me-to-a-long-random-string

# Supabase Storage (required for real uploads; optional if STORAGE_USE_MOCK=true)
# SUPABASE_SERVICE_ROLE_KEY is server-only — never put it in NEXT_PUBLIC_* frontend env.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=cloudvault-files
STORAGE_USE_MOCK=false

# AI provider
# Use `mock` for local/CI without keys.
# Use `openrouter` once OPENROUTER_API_KEY is set (backend/worker only).
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Free chat router (no OpenAI billing). Alternatives e.g. nvidia/nemotron-nano-9b-v2:free
OPENROUTER_MODEL=openrouter/free
# Use `local` to avoid paid embedding APIs (no free embedding models on OpenRouter)
OPENROUTER_EMBEDDING_MODEL=local
